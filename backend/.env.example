# MongoDB connection string. Must point to a replica set (Atlas free tier
# is a replica set by default) because the booking endpoint uses
# multi-document transactions.
MONGO_URI=mongodb+srv://<db_user>:<db_password>@fcluster/url

JWT_SECRET=replace_this_with_a_long_random_string

# How long an access token stays valid.
JWT_EXPIRES_IN=1d

# Port the API listens on.
PORT=5000

# Origin allowed to call the API (your frontend's origin).
FRONTEND_URL=http://localhost:3000
